# ── Moid-Share backend environment ───────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit `.env`.

# Runtime
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
# Number of proxy hops to trust (1 behind a single load balancer).
TRUST_PROXY=1

# Database (MongoDB Atlas connection string or local/docker Mongo)
MONGODB_URI=mongodb://127.0.0.1:27017/moidshare_dev

# JWT — generate strong secrets, e.g. `openssl rand -hex 48`
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Security
# Comma-separated allowed browser origins. Leave empty in prod for same-origin.
CORS_ORIGINS=
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Logging: error | warn | info | debug
LOG_LEVEL=debug
HTTP_LOG_FORMAT=dev
